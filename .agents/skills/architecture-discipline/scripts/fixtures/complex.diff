diff --git a/crates/nub-core/src/control.rs b/crates/nub-core/src/control.rs
new file mode 100644
--- /dev/null
+++ b/crates/nub-core/src/control.rs
@@ -0,0 +1,31 @@
+// Coordinates the worker lifecycle.
+// Owns the shared registry.
+// Starts the process.
+// Stops the process.
+// Waits for shutdown.
+use std::process::Command;
+use std::sync::{Arc, Mutex, OnceLock};
+trait WorkerStrategy {}
+struct LocalWorkerStrategy;
+impl WorkerStrategy for LocalWorkerStrategy {}
+struct WorkerManager {
+    running: bool,
+    stopped: bool,
+}
+enum WorkerState { Ready, Running, Stopped }
+struct WorkerCoordinator;
+struct WorkerRegistry;
+type WorkerBuilder = WorkerManager;
+fn install_test_hook() {}
+fn start(manager: Arc<Mutex<WorkerManager>>) {
+    let _ = Command::new("worker");
+    std::thread::spawn(|| {});
+}
