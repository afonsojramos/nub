{
  "name": "fs-generous-read-secrets",
  "policy": {
    "fs": [
      "{ROOT}",
      "!**/.env",
      "!**/.env.*",
      "!**/.env/**",
      "!**/.env.*/**",
      "!**/.envrc",
      "!{HOME}/.ssh/**",
      "!{HOME}/.pgpass",
      "!{HOME}/.gnupg/**",
      "!{HOME}/.config/git/credentials"
    ]
  },
  "relaxed": { "fs": true },
  "cases": [
    { "probe": "read", "target": "proj:pub.txt", "expect": true },
    { "probe": "read", "target": "home:notes.txt", "expect": true },
    { "probe": "read", "target": "proj:.env", "expect": false },
    { "probe": "read", "target": "proj:.env.local", "expect": false },
    { "probe": "read", "target": "proj:nested/.env/prod", "expect": false },
    { "probe": "read", "target": "proj:.envrc", "expect": false },
    { "probe": "read", "target": "home:.ssh/id_rsa", "expect": false },
    { "probe": "read", "target": "home:.pgpass", "expect": false },
    { "probe": "read", "target": "home:.gnupg/secring.gpg", "expect": false },
    { "probe": "read", "target": "home:.config/git/credentials", "expect": false }
  ]
}
