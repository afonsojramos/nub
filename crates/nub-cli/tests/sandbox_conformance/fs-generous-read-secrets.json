{
  "name": "fs-generous-read-secrets",
  "note": "macOS+Linux only: a read-DENY carved inside a broad read-ALLOW is a documented Windows residual — the AppContainer allowlist model cannot express deny-inside-allow (the inheritable read-allow wins), and the backend Degradation-reports it (backend/windows.rs deny_shadows_grant). Windows secret protection is proven the allowlist way by fs-read-confine: a secret OUTSIDE the allow-set is default-denied.",
  "policy": {
    "fs": [
      "{ROOT}",
      "!**/.env",
      "!**/.env.*",
      "!**/.env/**",
      "!**/.env.*/**",
      "!**/.envrc",
      "!{HOME}/.ssh/**",
      "!{HOME}/.pgpass",
      "!{HOME}/.gnupg/**",
      "!{HOME}/.config/git/credentials"
    ]
  },
  "relaxed": { "fs": true },
  "cases": [
    { "probe": "read", "target": "proj:pub.txt", "expect": true, "platforms": ["macos", "linux"] },
    { "probe": "read", "target": "home:notes.txt", "expect": true, "platforms": ["macos", "linux"] },
    { "probe": "read", "target": "proj:.env", "expect": false, "platforms": ["macos", "linux"] },
    { "probe": "read", "target": "proj:.env.local", "expect": false, "platforms": ["macos", "linux"] },
    { "probe": "read", "target": "proj:nested/.env/prod", "expect": false, "platforms": ["macos", "linux"] },
    { "probe": "read", "target": "proj:.envrc", "expect": false, "platforms": ["macos", "linux"] },
    { "probe": "read", "target": "home:.ssh/id_rsa", "expect": false, "platforms": ["macos", "linux"] },
    { "probe": "read", "target": "home:.pgpass", "expect": false, "platforms": ["macos", "linux"] },
    { "probe": "read", "target": "home:.gnupg/secring.gpg", "expect": false, "platforms": ["macos", "linux"] },
    { "probe": "read", "target": "home:.config/git/credentials", "expect": false, "platforms": ["macos", "linux"] }
  ]
}
